@page
@model IndexModel
@{
    ViewData["Title"] = "BetArena - Gestor de Apuestas";
}

<div class="container mt-5">
    <h1 class="mb-4">BetArena - Sistema de Gestión de Apuestas</h1>

    <!-- Formulario de Registro de Apuestas -->
    <div class="card mb-5">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Registrar Nueva Apuesta</h5>
        </div>
        <div class="card-body">
            <form id="betForm">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label for="userId" class="form-label">ID Usuario</label>
                        <input type="number" class="form-control" id="userId" min="1" required>
                    </div>
                    <div class="col-md-6">
                        <label for="game" class="form-label">Juego</label>
                        <select class="form-control" id="game" required>
                            <option value="">Seleccionar juego...</option>
                            <option value="Roulette">Roulette</option>
                            <option value="Blackjack">Blackjack</option>
                            <option value="Slots">Slots</option>
                            <option value="Poker">Poker</option>
                            <option value="Baccarat">Baccarat</option>
                        </select>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label for="stake" class="form-label">Stake (Monto Apostado)</label>
                        <input type="number" class="form-control" id="stake" step="0.01" min="0.01" required>
                    </div>
                    <div class="col-md-6">
                        <label for="winAmount" class="form-label">Win Amount (Monto Ganado)</label>
                        <input type="number" class="form-control" id="winAmount" step="0.01" min="0" required>
                    </div>
                </div>

                <button type="submit" class="btn btn-success">
                    <i class="bi bi-check-circle"></i> Registrar Apuesta
                </button>
                <div id="formMessage" class="mt-3"></div>
            </form>
        </div>
    </div>

    <!-- Botón de Actualización -->
    <div class="mb-3">
        <button type="button" class="btn btn-info" id="refreshBtn">
            <i class="bi bi-arrow-clockwise"></i> Actualizar Estadísticas
        </button>
    </div>

    <!-- Estadísticas por Juego -->
    <div class="card mb-4">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0">Estadísticas por Juego</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover" id="gamesTable">
                    <thead class="table-dark">
                        <tr>
                            <th>Juego</th>
                            <th>RTP (%)</th>
                        </tr>
                    </thead>
                    <tbody id="gamesTbody">
                        <tr>
                            <td colspan="2" class="text-center text-muted">
                                Sin datos. Registra apuestas para ver estadísticas.
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Estadísticas por Usuario -->
    <div class="card">
        <div class="card-header bg-warning text-dark">
            <h5 class="mb-0">Estadísticas por Usuario</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover" id="usersTable">
                    <thead class="table-dark">
                        <tr>
                            <th>ID Usuario</th>
                            <th>Total Apostado</th>
                            <th>Total Ganado</th>
                            <th>Balance (Ganancia/Pérdida)</th>
                        </tr>
                    </thead>
                    <tbody id="usersTbody">
                        <tr>
                            <td colspan="4" class="text-center text-muted">
                                Sin datos. Registra apuestas para ver estadísticas.
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/bets.js"></script>
}
